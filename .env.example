# Copy this file to .env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the client app.
# Never commit .env — it is gitignored.

# Clerk (https://dashboard.clerk.com)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Convex (https://dashboard.convex.dev)
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex Dashboard: set CLERK_JWT_ISSUER_DOMAIN (Clerk Frontend API URL)
# e.g. https://your-app.clerk.accounts.dev
# Convex Dashboard (account deletion action): set CLERK_SECRET_KEY (Clerk secret key)
# e.g. sk_live_... or sk_test_... — never prefix with EXPO_PUBLIC_

# Optional (web): canonical / Open Graph origin. Defaults to https://playbackfire.com for SEO.
# EXPO_PUBLIC_SITE_ORIGIN=https://playbackfire.com

# RevenueCat (https://app.revenuecat.com) — required for native in-app purchases
# Default: Test Store (debug / local / non-production). Same public key iOS + Android.
# Production release only: set EXPO_PUBLIC_REVENUECAT_USE_PRODUCTION_STORE=1 and appl_/goog_ keys
# (see .env.production and EAS production profile).
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=test_...
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=test_...
# EXPO_PUBLIC_REVENUECAT_USE_PRODUCTION_STORE=1

# RevenueCat webhook authorization header — set this in your Convex environment
# variables and in the RevenueCat dashboard webhook configuration. The same
# value must appear in the Authorization header of incoming webhook requests.
# REVENUECAT_WEBHOOK_AUTH_HEADER=shared_secret_here
