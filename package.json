{
  "name": "expo-rn-template",
  "version": "1.0.0",
  "description": "A reusable React Native template using Expo with TypeScript, navigation, and best practices",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "eas build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "seed:normalize": "tsx scripts/normalize-questions.ts"
  },
  "keywords": [
    "expo",
    "react-native",
    "template",
    "typescript",
    "navigation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mwijanarko1/Expo-RN-Template"
  },
  "packageManager": "bun@1.3.10",
  "patchedDependencies": {
    "expo-modules-core@55.0.22": "patches/expo-modules-core@55.0.22.patch"
  },
  "license": "MIT",
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.30",
    "@expo/metro-runtime": "~55.0.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.0",
    "@tanstack/react-query": "^5.90.16",
    "convex": "^1.19.0",
    "eslint-config-expo": "~55.0.0",
    "expo": "~55.0.14",
    "expo-auth-session": "~55.0.13",
    "expo-constants": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.12",
    "expo-notifications": "~55.0.18",
    "expo-router": "~55.0.12",
    "expo-screen-orientation": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "~19.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.15",
    "react-test-renderer": "19.2.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3"
  },
  "private": false
}
