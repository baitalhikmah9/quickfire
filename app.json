{
  "expo": {
    "name": "Backfire",
    "slug": "backfire",
    "scheme": "backfire",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/BF app logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/BF app logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/BF app logo.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/BF app logo.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "LANDSCAPE"
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image"
    ]
  }
}
