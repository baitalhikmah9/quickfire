{
  "expo": {
    "name": "Backfire",
    "slug": "backfire",
    "scheme": "backfire",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.playbackfire.app"
    },
    "android": {
      "package": "com.playbackfire.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F1C84A"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "LANDSCAPE"
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed21e462-752d-4c84-b233-c0fa0b48be25"
      }
    },
    "owner": "mikhailspeaks"
  }
}
