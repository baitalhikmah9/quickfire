{
  "expo": {
    "name": "BackFire",
    "slug": "backfire",
    "scheme": "backfire",
    "version": "1.0.4",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/BF in game logo safe.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF9F6"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "buildNumber": "5",
      "bundleIdentifier": "com.playbackfire.app",
      "infoPlist": {
        "UIStatusBarHidden": true
      }
    },
    "androidStatusBar": {
      "hidden": true
    },
    "android": {
      "versionCode": 5,
      "package": "com.playbackfire.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F1C84A"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "clerk",
              "host": "com.playbackfire.app.callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF9F6",
          "image": "./assets/BF in game logo safe.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/BF in game logo safe.png"
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": ["arm64-v8a", "armeabi-v7a"]
          }
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "LANDSCAPE"
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed21e462-752d-4c84-b233-c0fa0b48be25"
      }
    },
    "owner": "mikhailspeaks"
  }
}
